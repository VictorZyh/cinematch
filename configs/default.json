{
  "project_name": "cinematch",
  "random_seed": 42,
  "data": {
    "raw_dir": "data/raw/ml-latest-small",
    "processed_dir": "data/processed",
    "ratings_filename": "ratings.csv",
    "movies_filename": "movies.csv",
    "min_rating": 0.5,
    "positive_rating_threshold": 4.0
  },
  "split": {
    "test_interactions_per_user": 1,
    "min_train_interactions_per_user": 2
  },
  "candidate": {
    "num_candidates": 100,
    "num_similar_items": 50,
    "num_factors": 32,
    "popularity_weight": 0.30,
    "similarity_weight": 0.60,
    "matrix_factorization_weight": 0.10
  },
  "ranking": {
    "negative_samples_per_positive": 4,
    "model_type": "logistic_regression",
    "max_iter": 1000
  },
  "evaluation": {
    "k_values": [5, 10, 20]
  },
  "artifacts": {
    "output_dir": "artifacts"
  }
}
